---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const base = import.meta.env.BASE_URL;
---

<header
  id="header"
  class="absolute top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav class="max-w-[1600px] mx-auto px-6 py-6 md:px-8 md:py-8 flex flex-wrap md:flex-nowrap items-center justify-between gap-y-6">
    <div class="flex items-center gap-6">
      <a href={`${base}/`} class="flex items-center shrink-0">
        <img src={`${base}/Logo.svg`} alt="Logo" class="h-14 md:h-20 w-auto" />
      </a>
      <span class="text-xs font-mono uppercase tracking-[0.2em] text-gray-500 hidden sm:block mt-1">Marcos Winicyus</span>
    </div>
    
    <ul class="flex items-center justify-center gap-6 md:gap-10 w-full md:w-auto order-3 md:order-2 overflow-x-auto pb-2 md:pb-0">
      <li>
        <a
          href={`${base}/`}
          class="text-sm font-mono text-gray-600 hover:text-black transition-colors"
        >
          Home
        </a>
      </li>
      <li>
        <a
          href={`${base}/about`}
          class="text-sm font-mono text-gray-600 hover:text-black transition-colors"
        >
          About
        </a>
      </li>
      {
        hasProjects && (
          <li>
            <a
              href={`${base}/projects`}
              class="text-sm font-mono text-gray-600 hover:text-black transition-colors"
            >
              Projects
            </a>
          </li>
        )
      }
      <li>
        <a
          href={`${base}/articles`}
          class="text-sm font-mono text-gray-600 hover:text-black transition-colors"
        >
          Articles
        </a>
      </li>
    </ul>

    <div class="order-2 md:order-3">
      <a href={siteConfig.social?.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3 text-sm font-mono text-white bg-[#0A0D14] rounded-xl hover:bg-black transition-colors shadow-sm">
        Connect with Me <span class="ml-2">↗</span>
      </a>
    </div>
  </nav>
</header>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
