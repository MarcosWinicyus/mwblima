---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="py-24 sm:py-32 bg-[var(--color-bg-base)] border-b border-gray-200">
      <div class="max-w-[1400px] mx-auto px-8 w-full flex flex-col lg:flex-row">
        
        <!-- Left Static Column -->
        <div class="w-full lg:w-[30%] xl:w-[25%] shrink-0 flex flex-col pr-8 lg:pr-12 xl:pr-16 mb-12 lg:mb-0">
          <div class="sticky top-32">
            <span class="text-xs font-mono font-bold tracking-[0.2em] uppercase text-[var(--color-accent-primary)] mb-6 block">Featured Work</span>
            <h2 class="text-4xl lg:text-5xl font-display text-gray-900 mb-6 font-medium tracking-tight leading-tight">
              Selected<br/>Projects
            </h2>
            <p class="text-gray-600 font-sans mb-8 leading-relaxed text-sm md:text-base max-w-sm">
              A selection of projects that reflect my approach to solving complex problems.
            </p>
            <a href="#projects" class="text-sm font-semibold text-[var(--color-accent-primary)] hover:opacity-80 transition-all flex items-center gap-2 group">
              View all projects 
              <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
            </a>
          </div>
        </div>

        <!-- Right Scrolling Column -->
        <div class="w-full lg:w-[70%] xl:w-[75%] relative min-w-0">
          <div class="hidden lg:flex justify-end gap-3 mb-6 absolute -top-20 right-0">
             <button id="projects-prev" class="w-10 h-10 rounded-full border border-gray-300 flex items-center justify-center text-gray-400 hover:text-gray-900 hover:border-gray-900 transition-colors cursor-pointer" aria-label="Previous">
               <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
             </button>
             <button id="projects-next" class="w-10 h-10 rounded-full border border-gray-300 flex items-center justify-center text-gray-900 border-gray-900 hover:bg-gray-50 transition-colors cursor-pointer" aria-label="Next">
               <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
             </button>
          </div>

          <div id="projects-scroll" class="flex overflow-x-auto gap-6 snap-x snap-mandatory hide-scrollbar pb-8 -mx-8 px-8 lg:mx-0 lg:px-0">
            {siteConfig.projects.map((project, index) => {
              const Component = project.link ? "a" : "div";
              const linkProps = project.link ? { href: project.link, target: "_blank", rel: "noopener noreferrer" } : {};

              return (
                <Component
                  {...linkProps}
                  class="w-[85vw] sm:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)] shrink-0 snap-center sm:snap-start group flex flex-col bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-xl hover:border-gray-300 transition-all duration-300"
                >
                  <!-- Header Image Placeholder -->
                  <div class="w-full h-[200px] bg-[#111318] relative overflow-hidden flex items-center justify-center">
                     <!-- Abstract Graphic -->
                     <svg class="absolute inset-0 w-full h-full opacity-30" viewBox="0 0 400 220" xmlns="http://www.w3.org/2000/svg">
                        <g stroke="#ffffff" stroke-width="0.5" fill="none">
                           {Array.from({length: 15}).map((_, i) => (
                             <path d={`M -50 ${50 + i*10} Q 150 ${150 - i*15}, 450 ${100 + i*5}`} opacity={1 - i/15} />
                           ))}
                        </g>
                     </svg>
                  </div>
                  
                  <!-- Card Content -->
                  <div class="p-6 flex flex-col grow">
                    <span class="text-sm font-mono font-bold text-[var(--color-accent-primary)] mb-3">
                      {String(index + 1).padStart(2, '0')}
                    </span>
                    <h3 class="text-xl font-bold font-mono text-gray-900 mb-3 group-hover:text-[var(--color-accent-primary)] transition-colors">
                      {project.name}
                    </h3>
                    <p class="text-sm text-gray-600 mb-6 leading-relaxed">
                      {project.description}
                    </p>
                    
                    <div class="mt-auto flex flex-wrap gap-2">
                      {project.skills && project.skills.map((skill) => (
                        <span class="px-2.5 py-1 bg-white border border-gray-200 text-gray-600 rounded text-[11px] font-mono tracking-wide uppercase">
                          {skill}
                        </span>
                      ))}
                    </div>
                  </div>
                </Component>
              );
            })}
          </div>
        </div>
      </div>
    </section>
  )
}

<script>
  function setupProjectsScroll() {
    const container = document.getElementById('projects-scroll');
    const prevBtn = document.getElementById('projects-prev');
    const nextBtn = document.getElementById('projects-next');

    if (container && prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => {
        const cardWidth = container.querySelector('.group')?.clientWidth || 300;
        container.scrollBy({ left: -(cardWidth + 24), behavior: 'smooth' }); // 24px is gap-6
      });
      nextBtn.addEventListener('click', () => {
        const cardWidth = container.querySelector('.group')?.clientWidth || 300;
        container.scrollBy({ left: (cardWidth + 24), behavior: 'smooth' });
      });
    }
  }

  // Setup on initial load
  setupProjectsScroll();
</script>
