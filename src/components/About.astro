---
import { siteConfig } from "../config";
const base = import.meta.env.BASE_URL;
---

<section id="about" class="py-16 sm:py-24 bg-[var(--color-bg-base)]">
  <div class="max-w-[1000px] mx-auto px-8 w-full flex flex-col md:flex-row gap-12 lg:gap-16 items-start">
    
    <!-- Left Column: Photo -->
    <div class="w-full md:w-[35%] lg:w-[30%] shrink-0">
      <img 
        src={`${base}/profile.jpg`} 
        alt={siteConfig.name} 
        class="w-full aspect-square md:aspect-[4/5] object-cover shadow-sm rounded-xl"
      />
    </div>

    <!-- Right Column: Content -->
    <div class="w-full md:w-[65%] lg:w-[70%] flex flex-col">
      <h1 class="text-4xl md:text-5xl lg:text-6xl text-gray-900 mb-8 tracking-tight" style="font-family: 'Playfair Display', serif;">
        {siteConfig.name}
      </h1>
      
      <div class="space-y-6 text-gray-700 font-sans leading-relaxed text-base md:text-[17px]">
        {
          Array.isArray(siteConfig.aboutMe) 
            ? siteConfig.aboutMe.map((paragraph) => <p>{paragraph}</p>) 
            : <p>{siteConfig.aboutMe}</p>
        }
      </div>

      <!-- Social Links -->
      <div class="mt-12 pt-8 border-t border-gray-100 flex items-center gap-6 text-sm text-gray-500 font-sans">
        {siteConfig.social.twitter && <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 transition-colors">Twitter</a>}
        {siteConfig.social.linkedin && <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 transition-colors">LinkedIn</a>}
        {siteConfig.social.github && <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 transition-colors">GitHub</a>}
      </div>
    </div>
  </div>
</section>
